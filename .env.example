# ============================================
# RAG Knowledge - Environment Configuration
# ============================================
# Copy this file to .env and modify as needed.

# ---- Backend (FastAPI) ----
BACKEND_PORT=8001

# ---- Frontend (Vue + Vite, dev) ----
# Overrides the frontend repo's default (3007)
FRONTEND_PORT=3008

# ---- Frontend (Vue + Vite, prod preview) ----
FRONTEND_PREVIEW_PORT=4173

# ---- Web (Nuxt 3, dev) ----
# Overrides the web repo's default (3000)
WEB_PORT=3009

# ---- API ----
# Backend URL for Vite frontend proxy
VITE_API_BASE=http://localhost:8001
# Backend URLs for Nuxt web & backend services
NUXT_PUBLIC_API_BASE=http://localhost:8001/api
PDF_PARSER_API_URL=http://localhost:8001
DEEPAGENT_API_URL=http://localhost:8001
