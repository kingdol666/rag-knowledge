# ============================================
# RAG Knowledge Platform - Environment Variables
# ============================================
# Copy this file to .env and customize as needed.
# Env vars override config.yml values.
# ============================================

# Application mode: dev (visible terminals, auto-reload) | prod (background, optimized)
APP_MODE=dev

# Server ports — override config.yml settings
# BACKEND_PORT=8765
# WEB_PORT=6789

# Backend URL — auto-derived from BACKEND_PORT in dev mode
# BACKEND_URL=http://localhost:8765

# Tree file system storage path (relative to project root)
# TREE_STORAGE_PATH=./storage/tree-file-system

# Neo4j password (required for graph features)
# NEO4J_PASSWORD=123456

# Disable auto-reload (uvicorn --reload) for production
# NO_RELOAD=false

# Force UTF-8 encoding for Python subprocesses
PYTHONUTF8=1
