# ============================================
# RAG Knowledge Platform - Environment Variables
# ============================================
# Copy this file to .env and customize as needed.
# Env vars override config.yml values.
# ============================================

# Application mode: dev (auto-reload) | prod (optimized, no reload)
# Both modes start SILENTLY (no terminal windows). Logs go to:
#   backend/logs/desktop-stdout.log  and  web/logs/desktop-stdout.log
APP_MODE=dev

# Server ports — override config.yml settings
# BACKEND_PORT=8765
# WEB_PORT=6789

# Backend URL — auto-derived from BACKEND_PORT when unset
# BACKEND_URL=http://localhost:8765

# Tree file system storage path (relative to project root)
# Canonical location is ./storage/tree-file-system (NOT web/storage/...)
# TREE_STORAGE_PATH=./storage/tree-file-system

# Neo4j password (required for graph features; must match docker-compose)
# NEO4J_PASSWORD=123456

# Disable auto-reload (uvicorn --reload) for long sessions even in dev
# NO_RELOAD=false

# Force UTF-8 encoding for Python subprocesses (recommended on Windows)
PYTHONUTF8=1
PYTHONUNBUFFERED=1

# Optional: HuggingFace mirror for model downloads (China-friendly default used by ragctl model)
# HF_ENDPOINT=https://hf-mirror.com

# Optional: shared auth token when server.auth.enabled=true
# KB_AUTH_TOKEN=

# Optional: auto-check GitHub for newer project versions on agent start
# (actual pull still requires confirmation via ragctl update / knowledgebase-update)
# RAG_AUTO_UPDATE=true

# Optional: override GitHub identity for forks (used by ragctl version/update)
# RAG_GITHUB_OWNER=kingdol666
# RAG_GITHUB_REPO=rag-knowledge
# RAG_GITHUB_BRANCH=master
