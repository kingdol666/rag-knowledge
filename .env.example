# ============================================
# RAG Knowledge - Environment Configuration
# ============================================
# Copy this file to .env and modify as needed.

# Backend API port
BACKEND_PORT=8001

# Frontend dev server port
FRONTEND_PORT=3000

# Frontend preview (prod) port
FRONTEND_PREVIEW_PORT=4173

# Public API base URL (used by frontend proxy)
VITE_API_BASE=http://localhost:8001

# Backend service URLs
PDF_PARSER_API_URL=http://localhost:8001
DEEPAGENT_API_URL=http://localhost:8001
