# ============================================
# RAG Knowledge Platform — 统一环境配置
# ============================================
# 这是所有模块（backend / web / kb-mcp）的唯一 .env 配置源。
# 复制为 .env 后生效，优先级高于 config.yml：
#   ENV > config.yml > 代码内部默认值
#
# 启动方式:
#   手动:   cd backend && uv run python main.py
#           cd web    && node start.mjs
#   一键:   start.bat [dev|prod]
#   MCP:    Claude Code 通过 .mcp.json 自动启动 kb-mcp
#           kb-mcp 会自动检测并启动 backend + web
#
# 用法: cp .env.example .env  # 然后按需修改
# ============================================


# ── 运行模式 ───────────────────────────────────────────────
# dev  → 热重载、可见控制台窗口（开发用）
# prod → 无热重载、后台静默启动（生产用）
# 所有模块读取此变量，自动选择 config.yml 中的对应段落。
APP_MODE=dev


# ── 后端 (FastAPI) ─────────────────────────────────────────
# 后端 HTTP 服务端口。优先级:
#   BACKEND_PORT env > config.yml server.{mode}.backend_port > 代码默认 8001
BACKEND_PORT=8765

# 后端监听地址（默认 0.0.0.0 — 所有网络接口）
# BACKEND_HOST=0.0.0.0

# 后端完整 URL（设置此项后 BACKEND_PORT/BACKEND_HOST 被忽略）
# BACKEND_URL=http://localhost:8765

# 禁用热重载（设为 1 时即使 APP_MODE=dev 也不 reload）
# NO_RELOAD=0


# ── 前端 (Nuxt 3) ──────────────────────────────────────────
# 前端 Web 服务端口。优先级:
#   WEB_PORT env > config.yml server.{mode}.frontend_port > 代码默认 3000
WEB_PORT=6789

# 前端监听地址（默认 localhost）
# WEB_HOST=localhost

# 前端完整 URL（设置此项后 WEB_PORT/WEB_HOST 被忽略）
# WEB_URL=http://localhost:6789

# 兼容旧名（与 WEB_PORT 等价，优先级相同）
# FRONTEND_PORT=6789


# 知识库文件系统存储路径（基于项目根目录 rag-knowledge/）
# 优先级: .env > config.yml storage.tree_fs_root > 代码默认值
# 保持默认值即可，仅当需要把存储目录移到外部磁盘时才修改。
TREE_STORAGE_PATH=./storage/tree-file-system


# ── MinerU OCR 引擎（可选） ──────────────────────────────────
# MinerU API 的主机地址（仅用于 kb-mcp 的健康检查）
# MINERU_HOST=127.0.0.1

# MinerU API 端口（由 MinerU 启动脚本固定）
# MINERU_PORT=8764

# MinerU 完整 URL（设置此项后 MINERU_HOST/MINERU_PORT 被忽略）
# MINERU_URL=http://127.0.0.1:8764


# ── MCP / HTTP 客户端（kb-mcp） ─────────────────────────────
# kb-client HTTP 请求超时（秒），默认 30
# MCP_HTTP_TIMEOUT=30

# PDF 解析超时（秒），MinerU OCR 对大文件可能需数分钟，默认 300
# MCP_PARSE_TIMEOUT=300


# ── Neo4j 知识图谱 ─────────────────────────────────────────
# Neo4j 数据库密码。当 config.yml 中 graph.enabled=true 时必须设置。
# NEO4J_PASSWORD=changeme


# ── 共享令牌认证（Phase 0 轻量认证） ─────────────────────
# 保护 backend / web 的写/危险端点（config 修改、parse 上传、mineru restart、
# 索引重建、delete 类操作）。
#
# 启用方法：
#   1. 在 config.yml 中设 server.auth.enabled: true
#   2. 在此处设置 KB_AUTH_TOKEN（所有模块共享同一个 token）
#
# 行为：
#   - enabled=false（默认）→ 所有认证逻辑跳过，零配置本地使用完全不变。
#   - enabled=true → 写端点要求 Authorization: Bearer <token> 或 X-KB-Token 头。
#     GET / 读类端点始终放行。
#   - kb-mcp 自动从此变量读取 token 并附到所有请求（无需改工具签名）。
#   - 未设置此项且 enabled=true 时，backend 启动时生成随机 token 写到
#     storage/.runtime-token 并 log 提示（适合临时测试，不适合跨服务固定）。
#
# 生成随机 token: python -c "import secrets; print(secrets.token_hex(32))"
# KB_AUTH_TOKEN=


# ── 高级 / 调试 ─────────────────────────────────────────────
# 强制 Python UTF-8 编码（Windows 下避免 GBK 编码问题）
# PYTHONUTF8=1
