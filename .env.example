# ============================================
# RAG Knowledge - Environment Configuration
# ============================================
# Copy this file to .env and modify as needed.

# ---- Backend ----
BACKEND_PORT=8001

# ---- Frontend (dev) ----
# This overrides the frontend repo's default (3007)
FRONTEND_PORT=3008

# ---- Frontend (prod preview) ----
FRONTEND_PREVIEW_PORT=4173

# ---- API ----
# Backend URL for frontend proxy
VITE_API_BASE=http://localhost:8001
# PDF parser service
PDF_PARSER_API_URL=http://localhost:8001
# DeepAgent service
DEEPAGENT_API_URL=http://localhost:8001
