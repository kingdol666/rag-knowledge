   /**
+   * Resolve a docPath to its full storage-relative path.
+   *
+   * If *docPath* already contains a path separator (backslash or forward
+   * slash) it is treated as a full relative path and returned as-is (after
+   * normalisation).  If it is a bare filename (no separator), the path is
+   * prepended with the knowledge-base folder path looked up by *kbId*.
+   *
+   * Returns null when *kbId* is required but cannot be resolved.
+   */
+  async resolveDocPath(kbId: string, docPath: string): Promise<string | null> {
+    const sep = docPath.includes('\\') ? '\\' : docPath.includes('/') ? '/' : null
+    if (sep !== null) {
+      // Already a full (or at least path-containing) path ¨C return normalised.
+      return docPath.replace(/\\/g, '/')
+    }
+    // Bare filename ¨C resolve kbId to its folder path prefix.
+    const folder = await this.getKnowledgeBaseById(kbId)
+    if (!folder) {
+      // kbId didn't resolve ¨C try treating kbId itself as a folder path.
+      const byPath = await this.getFolderById(kbId)
+      if (byPath) {
+        return `${byPath.path.replace(/\\/g, '/')}/${docPath}`
+      }
+      return null
+    }
+    return `${folder.path.replace(/\\/g, '/')}/${docPath}`
+  }
