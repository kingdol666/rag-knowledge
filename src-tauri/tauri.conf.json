{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RAG Knowledge",
  "version": "1.0.0",
  "identifier": "com.ragknowledge.desktop",
  "build": {
    "frontendDist": "frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "RAG Knowledge Platform — 控制台",
        "width": 1280,
        "height": 860,
        "minWidth": 940,
        "minHeight": 620,
        "resizable": true,
        "fullscreen": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": ["nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.ico",
      "icons/icon.png"
    ],
    "windows": {
      "nsis": {
        "installerIcon": "icons/icon.ico",
        "installMode": "perMachine",
        "languages": ["en-US", "zh-CN"],
        "displayLanguageSelector": true
      }
    }
  }
}
